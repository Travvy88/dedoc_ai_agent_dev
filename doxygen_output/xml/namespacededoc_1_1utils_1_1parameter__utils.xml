      <memberdef kind="function" id="namespacededoc_1_1utils_1_1parameter__utils_1af5d36d11a5ab507299dfd4feb7b86602" prot="protected" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type></type>
