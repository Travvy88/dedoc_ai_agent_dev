<codeline lineno="162"><highlight class="normal"><sp/><sp/><sp/><sp/>dst<sp/>=<sp/>Image.new(</highlight><highlight class="stringliteral">&quot;RGB&quot;</highlight><highlight class="normal">,<sp/>(width,<sp/>height))</highlight></codeline>
