<codeline lineno="117"><highlight class="normal"><sp/><sp/><sp/><sp/></highlight><highlight class="keywordflow">if</highlight><highlight class="normal"><sp/>y_sum.shape[0]<sp/>&gt;<sp/>0<sp/></highlight><highlight class="keywordflow">and</highlight><highlight class="normal"><sp/>x_sum.shape[0]<sp/>&gt;<sp/>0:</highlight></codeline>
<codeline lineno="118"><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>y_top<sp/>=<sp/>max(0,<sp/>y_sum.min()<sp/>-<sp/>10)</highlight></codeline>
<codeline lineno="119"><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>y_bottom<sp/>=<sp/>min(im_height,<sp/>y_sum.max()<sp/>+<sp/>10)</highlight></codeline>
