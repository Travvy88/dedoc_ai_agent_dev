<codeline lineno="114"><highlight class="normal"><sp/><sp/><sp/><sp/>edges<sp/>=<sp/>maximum_filter(edges,<sp/>(10,<sp/>10))</highlight></codeline>
<codeline lineno="115"><highlight class="normal"><sp/><sp/><sp/><sp/>y_sum<sp/>=<sp/>np.arange(edges.shape[0])[edges.max(axis=1)<sp/>&gt;<sp/>0]</highlight></codeline>
