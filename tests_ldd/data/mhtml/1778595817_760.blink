@charset "utf-8";

.yhy-append-wrap { overflow: hidden; width: 100%; height: 40px; padding-top: 10px; }

.yhy-append { display: flex; align-items: center; }

.yhy-append .yhy-append-btn { display: flex; align-items: center; margin-right: 5px; padding: 5px 8px; background: rgb(236, 50, 55); box-shadow: rgba(0, 0, 0, 0.15) 0px -1px 30px; border-radius: 10px 10px 0px 0px; border: 0px; font-family: Arial; cursor: pointer; text-decoration: none; }

.yhy-append .yhy-append-icon { width: 24px; height: 24px; }

.yhy-append .yhy-append-icon { width: 24px; height: 24px; }

.yhy-append .yhy-btn-btttt .yhy-append-icon { width: 28px; height: 26px; }

.yhy-append .yhy-btn-btttt .append-icon > img { width: 100%; }

.yhy-append .yhy-btn-emc .yhy-append-icon { display: flex; align-items: center; justify-content: center; background: rgb(255, 255, 255); border-radius: 50%; }

.yhy-append .yhy-append-txt { margin-left: 5px; font-size: 14px; line-height: 16px; color: rgb(255, 255, 255); }